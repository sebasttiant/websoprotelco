# Local Docker defaults. Replace every value for shared, staging, or production environments.
POSTGRES_DB=websoprotelco
POSTGRES_USER=local_dev_user
POSTGRES_PASSWORD=local_dev_password_change_me
POSTGRES_PORT=5432

# Host-local app/script defaults. Use this value for pnpm db:migrate and
# pnpm db:create-admin commands run from your host shell after `docker compose up db`.
DATABASE_URL=postgresql://local_dev_user:local_dev_password_change_me@127.0.0.1:5432/websoprotelco

# Compose publishes the web app to localhost by default. Set WEB_HOST=0.0.0.0 only
# when a firewall and reverse proxy are configured intentionally.
WEB_HOST=127.0.0.1
WEB_PORT=8585

# Test database (used by pnpm test:db:reset and pnpm test:db:seed)
# POSTGRES_DB=websoprotelco_test
# DATABASE_URL=postgresql://local_dev_user:local_dev_password_change_me@127.0.0.1:5432/websoprotelco_test
