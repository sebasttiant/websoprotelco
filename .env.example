# ==============================================================================
# SOPROTELCO — Environment Variables
#
# LOCAL DEV:  Copy to .env, defaults work out of the box with docker compose.
# PRODUCTION: Change ALL passwords and set WEB_HOST=0.0.0.0 for external access.
# ==============================================================================

# --- PostgreSQL (docker-compose) ------------------------------------------
POSTGRES_DB=websoprotelco
POSTGRES_USER=local_dev_user
POSTGRES_PASSWORD=local_dev_password_change_me
POSTGRES_PORT=5432

# --- Application database connection --------------------------------------
# Used by pnpm db:migrate, pnpm seed:users, and other host-side scripts.
# Inside docker compose, services auto-construct this URL pointing to the
# postgres service — this value is only for host-side commands.
DATABASE_URL=postgresql://local_dev_user:local_dev_password_change_me@127.0.0.1:5432/websoprotelco

# Pool size for host-side scripts (docker compose services set their own).
DATABASE_POOL_MAX=10

# Set to "require" only when connecting to a remote DB with TLS (e.g. managed
# Postgres). For local Docker and same-host postgres, keep "disable".
DATABASE_SSL=disable

# --- Storage runtime ------------------------------------------------------
STORAGE_PROVIDER=local
# Catalog images are local-only `/uploads/...` paths in this phase. Do not configure remote origins.

# --- Web server -----------------------------------------------------------
# WEB_HOST=127.0.0.1 restricts to localhost (safe default).
# Set WEB_HOST=0.0.0.0 for VPS deployment with a firewall or reverse proxy.
WEB_HOST=127.0.0.1
WEB_PORT=8686
