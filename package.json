    "@testing-library/user-event": "^14.6.1",
    "@types/node": "24.13.2",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.9",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.10",
    "jsdom": "29.1.1",
